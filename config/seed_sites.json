{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Seed Sites Configuration",
  "description": "Initial seed sites for Stream A seed-crawl discovery lane",
  "type": "object",
  "required": ["seeds"],
  "properties": {
    "seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled", "domain", "start_urls", "allowed_prefixes", "blocked_fragments", "max_depth", "max_pages", "topic"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the seed"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this seed is active for crawling"
          },
          "domain": {
            "type": "string",
            "description": "Primary domain for this seed (e.g., federalreserve.gov)"
          },
          "start_urls": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Starting URLs for crawling"
          },
          "allowed_prefixes": {
            "type": "array",
            "items": {"type": "string"},
            "description": "URL prefixes that are in scope for crawling"
          },
          "blocked_fragments": {
            "type": "array",
            "items": {"type": "string"},
            "description": "URL fragments that should be excluded"
          },
          "max_depth": {
            "type": "integer",
            "description": "Maximum crawl depth (default: 2)"
          },
          "max_pages": {
            "type": "integer",
            "description": "Maximum pages to crawl per seed (default: 20)"
          },
          "topic": {
            "type": "string",
            "enum": ["macro catalysts", "market structure", "other"],
            "description": "Primary topic category for discovered candidates"
          }
        }
      }
    }
  },
  "seeds": [
    {
      "id": "federalreserve.gov",
      "enabled": true,
      "domain": "federalreserve.gov",
      "start_urls": [
        "https://www.federalreserve.gov/newsevents/pressreleases.htm",
        "https://www.federalreserve.gov/monetarypolicy.htm",
        "https://www.federalreserve.gov/boarddocs/speeches/default.htm"
      ],
      "allowed_prefixes": [
        "https://www.federalreserve.gov/newsevents/",
        "https://www.federalreserve.gov/monetarypolicy/",
        "https://www.federalreserve.gov/pressreleases/",
        "https://www.federalreserve.gov/publications/"
      ],
      "blocked_fragments": [
        "/about/",
        "/careers/",
        "/events/",
        "/experts/",
        "/people/",
        "/education/",
        "/programs/",
        "/museum/",
        "/archive/",
        "/category/",
        "/tag/",
        "/subscribe/"
      ],
      "max_depth": 2,
      "max_pages": 20,
      "topic": "macro catalysts"
    },
    {
      "id": "newyorkfed.org",
      "enabled": true,
      "domain": "newyorkfed.org",
