{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Memory Configuration",
  "description": "Configuration for adaptive memory system (cold-start thresholds, weights, decay)",
  "cold_start": {
    "min_samples_for_learning": 10,
    "full_learning_threshold": 25,
    "blend_formula": "linear"
  },
  "weights": {
    "accepted_weight": 10,
    "rejected_weight": 5,
    "filtered_weight": 3,
    "review_weight": 0,
    "human_multiplier": 2.0
  },
  "feedback_weights": {
    "bad_source_weight": 15,
    "good_source_weight": 30,
    "weak_accept_weight": 10,
    "promote_weight": 40,
    "suppress_weight": 10
  },
  "trust_score_bounds": {
    "min": 1,
    "max": 100
  },
  "decay": {
    "enabled": false,
    "half_life_days": 180,
    "min_age_days": 30
  },
  "logging": {
    "log_dir": "logs/source_memory",
    "log_updates": true
  }
}
