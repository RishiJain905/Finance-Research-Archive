{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Trust Tiers",
  "description": "Trust tier classification for candidate source domains",
  "type": "object",
  "properties": {
    "high": {
      "type": "array",
      "description": "High trust domains - official central bank and government sources",
      "items": {
        "type": "string"
      },
      "examples": [
        "federalreserve.gov",
        "newyorkfed.org",
        "treasury.gov",
        "fiscaldata.treasury.gov",
        "bankofcanada.ca",
        "ecb.europa.eu",
        "bankofengland.co.uk",
        "sec.gov"
      ]
    },
    "medium": {
      "type": "array",
      "description": "Medium trust domains - research institutions and policy organizations",
      "items": {
        "type": "string"
      },
      "examples": [
        "bis.org",
        "imf.org",
        "brookings.edu",
        "piie.com"
      ]
    },
    "low": {
      "type": "array",
      "description": "Low trust domains - everything else discovered from keyword search",
      "items": {
        "type": "string"
      },
      "examples": []
    }
  },
  "high": [
    "federalreserve.gov",
    "www.federalreserve.gov",
    "newyorkfed.org",
