{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Path Memory",
  "description": "Tracks path pattern-level performance and trust metrics",
  "type": "object",
  "required": ["domain", "path_pattern", "trust_score", "total_candidates", "accepted_count", "review_count", "rejected_count", "filtered_out_count"],
  "properties": {
    "domain": {
      "type": "string",
      "description": "The domain this path belongs to (e.g., brookings.edu)"
    },
    "path_pattern": {
      "type": "string",
      "description": "Literal path segment pattern (e.g., /events/, /press/, /research/)",
      "examples": ["/events/", "/press/", "/research/", "/category/", "/blog/"]
    },
    "trust_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Computed trust score for this path pattern (0-100)"
    },
    "total_candidates": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of candidates seen with this path pattern"
    },
    "accepted_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Candidates accepted from this path"
    },
    "accepted_human_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Candidates approved by human reviewer"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Candidates sent to review queue"
    },
    "review_human_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Human review decisions"
    },
    "rejected_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Candidates rejected"
    },
    "rejected_human_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Candidates rejected by human reviewer"
    },
    "filtered_out_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Candidates filtered out by score threshold"
    },
    "yield_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Ratio of accepted to total candidates"
    },
    "noise_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Ratio of (filtered_out + rejected) to total candidates"
    },
    "last_seen": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of last candidate with this path"
    },
    "first_seen": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of first candidate with this path"
    }
  }
}